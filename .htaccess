# Always revalidate CSS/JS/images so edits propagate without stale caches.
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|ico|webp)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Keep internal planning docs private: no HTTP access, no directory listing.
Options -Indexes
RedirectMatch 404 ^/docs(/|$)
RedirectMatch 404 ^/.+\.(md)$
